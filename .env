# ============================================================
# ENTORNO ACTIVO
# ============================================================
# Solo cambia esta línea para cambiar todo el comportamiento:
# - development = Muestra errores, usa DB de desarrollo
# - production  = Oculta errores, usa DB de producción
APP_ENV=development

# ============================================================
# MODO DEBUG
# ============================================================
# true  = Muestra errores detallados incluso en producción (SOLO PARA PRUEBAS)
# false = Respeta la configuración de APP_ENV
APP_DEBUG=true

# ============================================================================================================
# BASE DE DATOS - ||||DESARROLLO|||||
# ============================================================================================================

# ============================================================
# BASE DE DATOS - MYSQL
# ============================================================
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=
DB_MYSQL_DATABASE=pisciweb
DB_MYSQL_USERNAME=root
DB_MYSQL_PASSWORD=


# ============================================================
# SQL SERVER - AJUSTES DE RENDIMIENTO (LOCAL)
# ============================================================
# Reduce tiempos en Pending por handshake/login y evita esperas largas.
DB_SQLSRV_LOGIN_TIMEOUT=5
DB_SQLSRV_QUERY_TIMEOUT=90
DB_SQLSRV_ENCRYPT=false
DB_SQLSRV_TRUST_SERVER_CERTIFICATE=true
DB_SQLSRV_CONNECTION_POOLING=true
DB_SQLSRV_MARS=false

# ============================================================================================================
# BASE DE DATOS - PRODUCCIÓN
# ============================================================================================================
# Configura aquí tus servidores de producción
# Se usarán automáticamente cuando APP_ENV=production

# ============================================================
# BASE DE DATOS - mySQL PRODUCCIÓN
# ============================================================
DB_PROD_MYSQL_HOST=localhost
DB_PROD_MYSQL_PORT=8585
DB_PROD_MYSQL_DATABASE=pisciweb
DB_PROD_MYSQL_USERNAME=root
DB_PROD_MYSQL_PASSWORD=
